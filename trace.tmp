    "TASK_JSON"            "$task_json" \
    "LAYER1_COMMAND"       "$l1_command" \
    "LAYER1_TIMEOUT"       "$l1_timeout" \
    "LAYER2_INFO"          "$l2_info" \
    "INVESTIGATOR_FIX"     "$inv_fix" \
    "REQUIRED_BEHAVIORS"   "$required_behaviors" \
    "CONTEXT"              "$context"
}' ']'
