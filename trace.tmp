  "task_id": "T-003",
  "task_type": "implementation",
  "dev_phase_id": "core",
  "required_behaviors": [
    "有効トークン → next()",
    "無効トークン → 401",
    "期限切れ → 401"
  ],
  "description": "認証ミドルウェア実装",
  "status": "pending",
  "validation": {
    "layer_1": {
      "command": "vitest run src/auth.test.ts",
      "timeout_sec": 30
    }
  }
}

