{
  "name": "forge-research-harness-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Forge Research Harness - Monorepo",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test && npx playwright test",
    "test:unit": "vitest run",
    "test:unit:repository": "vitest run tests/unit/repository/",
    "e2e:settings": "npx tsx tests/e2e/settings-api.e2e.ts",
    "e2e": "npx playwright test",
    "e2e:ui": "npx playwright test --ui",
    "e2e:headed": "npx playwright test --headed",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/pg": "^8.10.9",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^9.2.2",
    "drizzle-orm": "^0.29.0",
    "hono": "^4.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "turbo": "^2.0.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
