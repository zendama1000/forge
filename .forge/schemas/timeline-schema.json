{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Video Harness Timeline Definition",
  "description": "timeline.json — OpenTimelineIO (OTIO) 骨格を踏襲した動画タイムライン定義。Timeline>Track>Clip>MediaReference の4階層に加え、レンダリングジョブ (RenderJob) と品質ゲート (QualityGate) を保持する。Forge Video Harness が scenarios/ 配下で共通入力として扱う単一情報源。source_range は OTIO/RationalTime 準拠で {start_time, duration} の非負数値で表現する。",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "tracks"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "タイムライン識別子。scenarios/{id}/timeline.json と 1:1 対応。",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "description": "timeline.json スキーマバージョン (semver 推奨)。",
      "default": "1.0.0"
    },
    "name": {
      "type": "string",
      "description": "人間可読のタイムライン名。"
    },
    "global_start_time": {
      "type": "number",
      "description": "タイムライン全体の開始時刻（秒、デフォルト0）。",
      "minimum": 0,
      "default": 0
    },
    "frame_rate": {
      "type": "number",
      "description": "タイムライン全体のフレームレート (fps)。",
      "exclusiveMinimum": 0,
      "default": 30
    },
    "tracks": {
      "type": "array",
      "description": "Track 配列。video/audio/subtitle 等を種別で分離する。minItems: 1（空トラックタイムラインは無意味）。",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "clips"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "トラック識別子。"
          },
          "kind": {
            "type": "string",
            "description": "トラック種別。OTIO Track.kind に準拠。",
            "enum": [
              "Video",
              "Audio",
              "Subtitle"
            ]
          },
          "name": { "type": "string" },
          "clips": {
            "type": "array",
            "description": "このトラック上のクリップ。時系列順で並べる。",
            "minItems": 0,
            "items": {
              "type": "object",
              "required": [
                "id",
                "source_range",
                "media_reference"
              ],
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "source_range": {
                  "type": "object",
                  "description": "OTIO TimeRange 準拠。start_time と duration はいずれも非負秒。duration は 0 禁止（ゼロ長クリップ不可）。",
                  "required": [
                    "start_time",
                    "duration"
                  ],
                  "properties": {
                    "start_time": {
                      "type": "number",
                      "minimum": 0,
                      "description": "メディア内の開始秒。"
                    },
                    "duration": {
                      "type": "number",
                      "exclusiveMinimum": 0,
                      "description": "クリップの長さ（秒）。0 以下は禁止（開始>終了の結果となる負 duration を含む）。"
                    }
                  },
                  "additionalProperties": true
                },
                "media_reference": {
                  "type": "object",
                  "description": "MediaReference。target_url は可能な限り既存ファイルを指すこと（存在検証は validator が file_exists で実施）。",
                  "required": [
                    "target_url"
                  ],
                  "properties": {
                    "target_url": {
                      "type": "string",
                      "description": "メディアファイルへのパス（相対 or 絶対）。"
                    },
                    "available_range": {
                      "type": "object",
                      "description": "メディア側の利用可能範囲（任意）。",
                      "properties": {
                        "start_time": { "type": "number", "minimum": 0 },
                        "duration": { "type": "number", "exclusiveMinimum": 0 }
                      },
                      "additionalProperties": true
                    }
                  },
                  "additionalProperties": true
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "render_jobs": {
      "type": "array",
      "description": "Render パイプラインのジョブ宣言（任意）。status は限定 enum。",
      "items": {
        "type": "object",
        "required": [
          "id",
          "status"
        ],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "status": {
            "type": "string",
            "description": "ジョブの現在状態。ハーネスが状態機械として扱う。",
            "enum": [
              "pending",
              "running",
              "succeeded",
              "failed"
            ]
          },
          "output_path": { "type": "string" },
          "started_at": { "type": "string" },
          "finished_at": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "quality_gate": {
      "type": "object",
      "description": "QualityGate 埋め込み（任意）。scenarios 側の quality_gates と同型で、timeline 単体でも Phase 3 検証に渡せるよう保持する。",
      "properties": {
        "required_mechanical_gates": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ffprobe_exists",
              "duration_check",
              "size_threshold"
            ]
          },
          "minItems": 1
        }
      },
      "additionalProperties": true
    }
  }
}
