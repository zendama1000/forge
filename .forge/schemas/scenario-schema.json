{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Video Harness Scenario Definition",
  "description": "scenarios/{id}/scenario.json — 動画作成ハーネスのシナリオ定義。Forge v3.2 の sprint-contract に相当し、シナリオ固有の入力源・品質ゲート・エージェント向けプロンプト注入を宣言する。",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "type",
    "input_sources",
    "quality_gates",
    "agent_prompt_patch"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "シナリオ識別子。scenarios/{id}/ ディレクトリ名と一致すること。英数字+ハイフン+アンダースコアのみ。",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "description": "シナリオ種別。ハーネスの dispatch テーブルで使われる。",
      "enum": [
        "image_slideshow",
        "video_edit",
        "ai_avatar",
        "screen_record",
        "subtitle_overlay",
        "audio_sync"
      ]
    },
    "version": {
      "type": "string",
      "description": "シナリオ定義のバージョン。semver 推奨。",
      "default": "1.0.0"
    },
    "description": {
      "type": "string",
      "description": "人間向け説明文。何を作るシナリオかを1-2行で記述。"
    },
    "input_sources": {
      "type": "array",
      "description": "このシナリオが必要とする入力源の宣言。",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "image_dir",
              "video_file",
              "audio_file",
              "text_file",
              "subtitle_file",
              "script_file",
              "config_file"
            ]
          },
          "path": { "type": "string" },
          "required": { "type": "boolean", "default": true },
          "glob": { "type": "string" },
          "description": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "quality_gates": {
      "type": "object",
      "description": "Phase 3 統合検証で実行される品質ゲート。required_mechanical_gates は最低1件必須（空配列禁止）。",
      "required": ["required_mechanical_gates"],
      "properties": {
        "required_mechanical_gates": {
          "type": "array",
          "description": "機械的に検証可能なゲート（ffprobe/size/duration 等）。実装後に自動実行される。",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "command"],
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" },
              "command": { "type": "string" },
              "expect": { "type": "string" },
              "blocking": { "type": "boolean", "default": true }
            },
            "additionalProperties": true
          }
        },
        "human_checks": {
          "type": "array",
          "description": "Phase 4 で人間が目視確認する項目。",
          "items": {
            "type": "object",
            "required": ["id", "description"],
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "agent_prompt_patch": {
      "type": "string",
      "description": "Implementer/Investigator に追加注入するプロンプトテキスト。シナリオ固有の制約・ヒントを宣言する。文字列のみ許容（オブジェクト/配列禁止）。",
      "minLength": 0
    }
  }
}
