{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "mutation-audit.json schema",
  "description": "Forge Harness mutation-audit.json 設定ファイルのスキーマ",
  "type": "object",
  "required": ["mutation_audit"],
  "properties": {
    "mutation_audit": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "skip_task_types": { "type": "array" },
        "phase_config": { "type": "object" },
        "mutant_count": { "type": "object" },
        "survival_threshold": { "type": "object" },
        "error_rate_threshold": { "type": "number" },
        "behavior_coverage_required": { "type": "number" },
        "max_plan_attempts": { "type": "number" },
        "max_audit_attempts": { "type": "number" },
        "runner_timeout_per_mutant_sec": { "type": "number" },
        "auditor_timeout_sec": { "type": "number" },
        "model": { "type": "string" }
      }
    }
  }
}
