{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "research.json schema",
  "description": "Forge Harness research.json 設定ファイルのスキーマ",
  "type": "object",
  "required": ["models", "timeouts"],
  "properties": {
    "parallel_researchers": {
      "type": "boolean"
    },
    "models": {
      "type": "object",
      "required": ["scope_challenger", "researcher", "synthesizer"],
      "properties": {
        "scope_challenger": { "type": "string" },
        "researcher": { "type": "string" },
        "synthesizer": { "type": "string" },
        "criteria_generation": { "type": "string" },
        "final_report": { "type": "string" }
      }
    },
    "perspectives": {
      "type": "object",
      "properties": {
        "fixed": { "type": "array" },
        "max_dynamic": { "type": "number" }
      }
    },
    "disallowed_tools": {
      "type": "object",
      "properties": {
        "scope_challenger": { "type": "string" },
        "synthesizer": { "type": "string" },
        "researcher": { "type": "string" }
      }
    },
    "timeouts": {
      "type": "object",
      "required": ["researcher_sec"],
      "properties": {
        "scope_challenger_sec": { "type": "number" },
        "researcher_sec": { "type": "number" },
        "synthesizer_sec": { "type": "number" },
        "criteria_generation_sec": { "type": "number" },
        "final_report_sec": { "type": "number" }
      }
    }
  }
}
