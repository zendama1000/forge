1: #!/bin/bash
2: # common.sh — Forge Harness 共有ユーティリティ関数
3: # 使い方: source "${PROJECT_ROOT}/.forge/lib/common.sh"
4: #
5: # 前提変数（呼び出し元で定義すること）:
6: #   PROJECT_ROOT    — プロジェクトルートの絶対パス
7: #   ERRORS_FILE     — errors.jsonl のパス（record_error, validate_json が使用）
8: #   json_fail_count — JSON検証失敗カウンタ（validate_json が読み書き。0で初期化すること）
9: #   RESEARCH_DIR    — エラー記録のコンテキスト識別子（未定義時は "unknown" にフォールバック）
10: #
11: # 注意: Opus モデルは応答が遅い場合がある（Task Planner で ~9 分以上の事例あり）。
12: # Claude CLI -p モードは処理完了後に初めて stdout 出力するため、timeout で kill されると
13: # .pending ファイルが空→削除される。Opus 使用時は development.json の timeout_sec を
14: # 1800 以上に設定することを推奨。
15: 
16: # ===== カラー定数 =====
17: RED='\033[0;31m'
18: YELLOW='\033[1;33m'
19: GREEN='\033[0;32m'
20: CYAN='\033[0;36m'
21: BOLD='\033[1m'
22: DIM='\033[2m'
23: NC='\033[0m'
24: 
